{
  "name": "@orquestra/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI tool for scanning Solana programs and checking on-chain IDL availability",
  "bin": {
    "orquestra-scan": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "scan": "bun run src/index.ts scan",
    "check-idl": "bun run src/index.ts check-idl",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@solana/web3.js": "^1.87.6",
    "bs58": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.5"
  }
}
