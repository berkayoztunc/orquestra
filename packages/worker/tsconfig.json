{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "target": "ES2020",
    "lib": [
      "ES2020",
      "WebWorker"
    ],
    "types": ["@cloudflare/workers-types"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@shared/*": [
        "../shared/src/*"
      ],
      "@/*": [
        "./src/*"
      ]
    },
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src",
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
